# ─────────────────────────────────────────────────────────────────────────────
# XanhSM Bot — Environment Variables Template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Your OpenAI API key (get it from platform.openai.com)
OPENAI_API_KEY=sk-...your-key-here...

# ── LLM Models ────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_MINI=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
# Options: development | production
ENVIRONMENT=development
DEBUG=false

# ── Authentication ────────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require login
# Set strong credentials before deploying to production!
AUTH_ENABLED=false
BOT_USERNAME=admin
BOT_PASSWORD=changeme_strong_password_here
# Required when AUTH_ENABLED=true — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
CHAINLIT_AUTH_SECRET=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max messages per user per minute (default: 10)
RATE_LIMIT_PER_MINUTE=10

# ── Cost Guard ────────────────────────────────────────────────────────────────
# Max OpenAI spend per day in USD (default: $5.00)
DAILY_BUDGET_USD=5.0

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Leave empty to use in-memory fallback (works for single-instance deployments)
# Set this when deploying multiple instances (e.g. REDIS_URL=redis://localhost:6379/0)
REDIS_URL=

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PATH=.chromadb
COLLECTION_NAME=xanhsm_qa
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
TOP_K=3

# ── Data Paths ────────────────────────────────────────────────────────────────
FEEDBACK_PATH=data/feedback.jsonl
QA_DATA_PATH=data/qa.json

# ── App Metadata ──────────────────────────────────────────────────────────────
APP_NAME=XanhSM Bot
APP_VERSION=1.0.0
